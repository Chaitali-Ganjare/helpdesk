# Server
PORT=3000
NODE_ENV=                    # set to "production" on the deployed Railway API service —
                              # gates cross-domain session cookie attributes, see lib/auth.ts

# Database
DATABASE_URL=

# Auth
BETTER_AUTH_SECRET=          # openssl rand -base64 32
BETTER_AUTH_URL=             # e.g. http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS= # comma-separated, e.g. http://localhost:5173,https://app.example.com

# CORS — comma-separated list of allowed origins for the Express CORS middleware.
# Defaults to http://localhost:5173 if unset (dev only). Set the production
# Railway web service URL here before deploying (web and API are separate
# Railway services, so this is a cross-origin request).
CORS_ORIGIN=                 # e.g. https://helpdesk-web.up.railway.app

# Seed (used by scripts/seed-user.ts)
SEED_EMAIL=
SEED_PASSWORD=
SEED_NAME=Admin
SEED_ROLE=ADMIN

# Anthropic
ANTHROPIC_API_KEY=

# Postmark
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_INBOUND_USERNAME=   # Basic Auth username for the inbound webhook; embed in the Postmark-configured URL
POSTMARK_INBOUND_PASSWORD=   # Basic Auth password for the inbound webhook; embed in the Postmark-configured URL

# Sentry (error tracking) — leave blank to disable (e.g. local dev without a Sentry project)
SENTRY_DSN=
