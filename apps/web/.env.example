# Copy to .env.local (Vite-ignored by default) and fill in values.

# Sentry (error tracking) — leave blank to disable (e.g. local dev without a Sentry project)
VITE_SENTRY_DSN=

# API base URL. Leave blank in dev — the Vite proxy forwards /api/* to
# localhost:3000 (see vite.config.ts). Required in production, since the web
# app and API are deployed as separate Railway services on different origins:
# set to the API service's public URL, e.g. https://helpdesk-api.up.railway.app
VITE_API_URL=
