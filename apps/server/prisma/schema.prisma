generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Better Auth models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(AGENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  sessions      Session[]
  accounts      Account[]
  assignedTickets Ticket[]
  replies       Reply[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Helpdesk models ──────────────────────────────────────────────

model Ticket {
  id        String   @id @default(cuid())
  subject   String
  body      String   @db.Text
  fromEmail String
  fromName  String?
  // Not a DB-native enum — the frontend can't import Prisma's generated
  // types, so the canonical value lists live once in
  // packages/core/src/enums/ticket-status.ts, validated at the application
  // layer (zod) on every write instead of by MySQL.
  status String @default("OPEN")
  // AI-classified on creation (see services/tickets.ts's classifyTicket) —
  // nullable because classification happens asynchronously, after the
  // ticket row already exists. Canonical values: ticket-category.ts.
  category String?
  // Canonical values: packages/core/src/enums/ticket-priority.ts.
  priority  String?
  messageId String?  @unique
  // Assigned agent/admin working the ticket — nullable, unassigned by default.
  // Mutually exclusive with assignedToAI (enforced in services/tickets.ts's
  // assignTicket, not the DB): a ticket is unassigned, assigned to a human,
  // or assigned to AI, never more than one of those at once.
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  // True when the ticket is assigned to "AI" instead of a human agent/admin —
  // there's no AI user row (User is tied into better-auth's login/session
  // model, which doesn't apply here), so this is a plain flag rather than
  // another assignedToId value. Also feeds the dashboard's "resolved by AI"
  // stat (see getDashboardStats): assignedToAI + status RESOLVED/CLOSED.
  assignedToAI Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  replies   Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  body      String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  // Not a DB-native enum — canonical values live in
  // packages/core/src/enums/reply-sender-type.ts, validated at the
  // application layer (zod), same convention as Ticket.status/category/priority.
  // Defaults to AGENT since the only creation path today is the authenticated
  // agent-reply route; a future customer-reply path (e.g. inbound email) would
  // pass CUSTOMER explicitly.
  senderType String  @default("AGENT")
  createdAt DateTime @default(now())
}

// ─── Enums ────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AGENT
}
