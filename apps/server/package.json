{
  "name": "@helpdesk/server",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "seed:user": "bun run --env-file .env scripts/seed-user.ts",
    "start:test": "bun run --env-file .env.test src/index.ts"
  },
  "dependencies": {
    "@prisma/client": "5",
    "better-auth": "^1.6.22",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "prisma": "5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "typescript": "^5.5.3"
  }
}
