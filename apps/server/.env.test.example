# Test environment — copy to .env.test and fill in values.
# This database is wiped and re-migrated before every e2e test run.
# Use a dedicated MySQL database; NEVER point this at your dev/prod database.

PORT=3000

DATABASE_URL=mysql://root:password@localhost:3306/helpdesk_test

BETTER_AUTH_SECRET=test-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

CORS_ORIGIN=http://localhost:5173

# Test admin user seeded by global-setup before each run
SEED_EMAIL=admin@test.local
SEED_PASSWORD=Test1234!
SEED_NAME=Test Admin
SEED_ROLE=ADMIN

# Postmark inbound webhook Basic Auth (see /api/webhooks/email)
POSTMARK_INBOUND_USERNAME=test-postmark-user
POSTMARK_INBOUND_PASSWORD=test-postmark-password

# Postmark's official test-mode token — validates outbound Send API calls
# (see services/tickets.ts's sendReplyEmail) without delivering real email
# or requiring a real account/domain. Never use a real server token here.
POSTMARK_SERVER_TOKEN=POSTMARK_API_TEST
POSTMARK_FROM_EMAIL=support@test.local

# Left blank — disables the Sentry SDK so e2e/test runs never send events
SENTRY_DSN=
